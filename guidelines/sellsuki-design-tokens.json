{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "name": "Sellsuki Design System",
  "version": "1.2.0",
  "description": "Universal design tokens for Sellsuki — importable by any AI tool or design tool",
  "brand": {
    "name": "Sellsuki",
    "product": "E-commerce management platform for Thai merchants",
    "mood": "Professional, clean, trustworthy, light, airy, functional",
    "personality": "Clarity over decoration"
  },
  "color": {
    "primary": {
      "50": "#f0f9ff",
      "100": "#e0f2fe",
      "200": "#bae6fd",
      "300": "#7dd3fc",
      "400": "#38bdf8",
      "500": "#32a9ff",
      "600": "#1b8bf5",
      "700": "#1d6cb4",
      "800": "#1e5a8f",
      "900": "#194f8f"
    },
    "gray": {
      "50": "#f9fafb",
      "100": "#f3f4f6",
      "200": "#e5e7eb",
      "300": "#d1d5db",
      "400": "#9ca3af",
      "500": "#6b7280",
      "600": "#4b5563",
      "700": "#374151",
      "800": "#1f2937",
      "900": "#111827"
    },
    "success": {
      "light": "#d1fae5",
      "solid": "#059669",
      "dark": "#065f46"
    },
    "warning": {
      "light": "#fef3c7",
      "solid": "#d97706",
      "dark": "#92400e"
    },
    "danger": {
      "light": "#ffe4e6",
      "solid": "#e11d48",
      "dark": "#9f1239"
    },
    "semantic": {
      "text-primary": "#1f2937",
      "text-secondary": "#6b7280",
      "border": "#e5e7eb",
      "background": "#ffffff",
      "surface": "#f9fafb"
    }
  },
  "typography": {
    "font-family": {
      "body": "'DB HeaventRounded', 'Noto Sans Thai', sans-serif",
      "button": "'Inter', sans-serif"
    },
    "font-size": {
      "xs": "12px",
      "sm": "14px",
      "md": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "28px",
      "4xl": "32px"
    },
    "font-weight": {
      "normal": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    }
  },
  "spacing": {
    "page-padding-desktop": "24px",
    "page-padding-mobile": "16px",
    "card-gap": "16px",
    "form-field-gap": "16px",
    "section-gap": "32px",
    "xs": "4px",
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "2xl": "48px"
  },
  "border": {
    "radius": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "width": "1px",
    "color": "#e5e7eb"
  },
  "shadow": {
    "none": "none",
    "sm": "0px 1px 2px 0px rgba(0,0,0,0.05)",
    "md": "0px 4px 6px -1px rgba(0,0,0,0.07)"
  },
  "layout": {
    "navbar-height": "72px",
    "sidebar-width": "280px",
    "max-content-width": "1280px"
  },
  "button": {
    "variants": ["primary", "secondary", "outline", "ghost", "destructive", "link"],
    "sizes": {
      "sm": "32px",
      "md": "36px",
      "lg": "40px",
      "xl": "44px"
    },
    "default-variant": "primary",
    "default-size": "md",
    "rules": "Max 1 primary button per view"
  },
  "components": {
    "data-entry": ["DSButton", "IconButton", "ButtonGroup", "DSInput", "DSTextarea", "DSCheckbox", "CheckboxGroup", "DSRadio", "RadioGroup", "Switch", "Dropdown", "DatePicker", "SearchField", "ColorPicker", "FileUpload", "TagInput", "Rating", "TransferList"],
    "data-display": ["DSTable", "Card", "CardHeader", "CardBody", "CardFooter", "StatCard", "Statistic", "Badge", "Tag", "Avatar", "AvatarGroup", "Timeline", "Tree", "EmptyState", "Skeleton"],
    "navigation": ["TopNavbar", "Sidebar", "Breadcrumb", "Tabs", "Stepper", "Pagination"],
    "feedback": ["Alert", "Modal", "Drawer", "ConfirmDialog", "Notification", "toast", "ToastContainer", "Tooltip", "Popover", "ProgressBar", "Spinner"],
    "layout": ["Divider", "Menu", "ImagePreview"]
  }
}
